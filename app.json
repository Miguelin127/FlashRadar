{
  "expo": {
    "name": "FlashRadar",
    "slug": "flashradar-app",
    "sdkVersion": "54.0.0",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.miguelin1.flashradarapp",
      "buildNumber": "5",
      "infoPlist": {
        "NSUserNotificationsUsageDescription": "FlashRadar sends you instant alerts when rare deals and lightning offers drop near you."
      }
    },
    "android": {
      "package": "com.miguelin1.flashradarapp",
      "versionCode": 3,
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#ffffff"
      },
      "permissions": [
        "RECEIVE_BOOT_COMPLETED",
        "POST_NOTIFICATIONS",
        "VIBRATE"
      ]
    },
    "extra": {
      "eas": {
        "projectId": "10e28c1b-9e8d-4608-b9e1-9b3a263a1aea"
      }
    },
    "owner": "miguelin1",
    "plugins": [
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#FF7A00",
          "sounds": []
        }
      ]
    ]
  }
}