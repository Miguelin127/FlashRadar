{
  "expo": {
    "name": "FlashRadar",
    "slug": "flashradar-app",
    "sdkVersion": "55.0.0",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.miguelin1.flashradarapp",
      "buildNumber": "7",
      "config": {
        "googleMapsApiKey": "AIzaSyBeldwLWhSlf0bYzJHBmtce4R1XoEnXBXc"
      },
      "infoPlist": {
        "NSUserNotificationsUsageDescription": "FlashRadar sends you instant alerts when rare deals and lightning offers drop near you.",
        "NSLocationWhenInUseUsageDescription": "FlashRadar uses your location to show nearby deals, clearance sales, and store-specific offers within your area. For example, we'll alert you when a Target 2 miles away has a clearance sale on electronics.",
        "NSLocationAlwaysUsageDescription": "FlashRadar uses your location to detect nearby deals and send you alerts when rare finds appear at stores close to you.",
        "ITSAppUsesNonExemptEncryption": false
      },
      "splash": {
        "image": "./assets/splash.png",
        "resizeMode": "contain",
        "backgroundColor": "#000000"
      },
      "requireFullScreen": true
    },
    "android": {
      "package": "com.miguelin1.flashradarapp",
      "versionCode": 3,
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#ffffff"
      },
      "permissions": [
        "RECEIVE_BOOT_COMPLETED",
        "POST_NOTIFICATIONS",
        "VIBRATE"
      ],
      "splash": {
        "image": "./assets/splash.png",
        "resizeMode": "contain",
        "backgroundColor": "#000000"
      }
    },
    "extra": {
      "eas": {
        "projectId": "10e28c1b-9e8d-4608-b9e1-9b3a263a1aea"
      }
    },
    "owner": "miguelin1",
    "plugins": [
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#FF7A00",
          "sounds": []
        }
      ],
      "expo-web-browser",
      "expo-font",
      "expo-apple-authentication"
    ],
    "scheme": "flashradar"
  }
}