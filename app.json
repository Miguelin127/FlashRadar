{
  "expo": {
    "name": "FlashRadar",
    "slug": "flashradar-app",
    "version": "1.0.2",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.miguelin1.flashradarapp",
      "config": {
        "googleMapsApiKey": "AIzaSyBeldwLWhSlf0bYzJHBmtce4R1XoEnXBXc"
      },
      "infoPlist": {
        "NSUserNotificationsUsageDescription": "FlashRadar sends you instant alerts when rare deals and lightning offers drop near you.",
        "NSLocationWhenInUseUsageDescription": "FlashRadar uses your location to show nearby deals, clearance sales, and store-specific offers within your area.",
        "NSLocationAlwaysUsageDescription": "FlashRadar uses your location to detect nearby deals and send you alerts when rare finds appear at stores close to you.",
        "ITSAppUsesNonExemptEncryption": false,
        "CFBundleURLTypes": [
          {
            "CFBundleURLSchemes": [
              "com.googleusercontent.apps.2868928124-g7ha6o9jvfj9ul9dectbn24ksmlol7q5"
            ]
          }
        ]
      },
      "requireFullScreen": true
    },
    "android": {
      "package": "com.miguelin1.flashradarapp",
      "versionCode": 4,
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#ffffff"
      },
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "POST_NOTIFICATIONS",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE"
      ],
      "googleServicesFile": "./google-services.json",
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyBeldwLWhSlf0bYzJHBmtce4R1XoEnXBXc"
        }
      }
    },
    "extra": {
      "eas": {
        "projectId": "10e28c1b-9e8d-4608-b9e1-9b3a263a1aea"
      }
    },
    "owner": "miguelin1",
    "plugins": [
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#FF7A00",
          "sounds": []
        }
      ],
      "expo-web-browser",
      "expo-font",
      "expo-apple-authentication",
      "expo-sharing",
      "expo-status-bar",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash.png",
          "resizeMode": "contain",
          "backgroundColor": "#000000"
        }
      ]
    ],
    "scheme": "flashradar"
  }
}