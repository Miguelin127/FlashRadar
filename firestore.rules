rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null && (
        request.auth.uid == "Rg0hPUxtKjW50sKM9LCY0lk4t3h2" ||
        request.auth.token.email == "miguelx.x127@gmail.com"
      );
    }

    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      match /{subCollection}/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    match /deals/{dealId} {
      allow read: if true;
      allow write, delete: if isAdmin();
    }
    match /deals_live/{dealId} {
      allow read: if true;
      allow write, delete: if isAdmin();
    }
    match /deals_online/{dealId} {
      allow read: if true;
      allow write, delete: if isAdmin();
    }
    match /deals_online_raw/{dealId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /deals_online_amazon/{dealId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /deals_online_walmart/{dealId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /deals_online_target/{dealId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /best_buy_deals/{dealId} {
      allow read: if true;
      allow write, delete: if isAdmin();
    }
    match /target_deals/{dealId} {
      allow read: if true;
      allow write, delete: if isAdmin();
    }
    match /deal_ingestion_logs/{logId} {
      allow read, write: if isAdmin();
    }
    match /deal_ingestion_errors/{errId} {
      allow read, write: if isAdmin();
    }
    match /ingestionLogs/{docId} {
      allow read, write: if isAdmin();
    }
    match /notifications/{notifId} {
      allow read, write: if request.auth != null;
    }
    match /campaigns/{docId} {
      allow read: if request.auth != null;
      allow write, delete: if request.auth != null && request.auth.uid == resource.data.uid;
      allow create: if request.auth != null;
    }
    match /creators/{docId} {
      allow read, write: if request.auth != null && request.auth.uid == docId;
    }
    match /payouts/{docId} {
      allow read: if request.auth != null && request.auth.uid == resource.data.uid;
      allow create: if request.auth != null;
    }
    match /creatorLinks/{docId} {
      allow read, write: if request.auth != null && request.auth.uid == resource.data.uid;
      allow create: if request.auth != null;
    }
    match /referrals/{docId} {
      allow read, write: if request.auth != null;
    }
    match /stripe_events/{docId} {
      allow read, write: if false;
    }
    match /checkout_sessions/{docId} {
      allow read: if request.auth != null && request.auth.uid == resource.data.uid;
      allow create: if request.auth != null;
    }
    match /products/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
